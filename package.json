{
  "name": "vidpipe-copilot-plugin",
  "version": "0.1.0",
  "description": "GitHub Copilot CLI plugin for AI-powered video editing with Gemini analysis, FFmpeg tools, and viral content generation",
  "type": "module",
  "scripts": {
    "bundle": "npx esbuild packages/mcp-server/src/server.ts --bundle --platform=node --target=node20 --format=cjs --outfile=bin/mcp-server.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "copilot",
    "github-copilot",
    "video-editing",
    "ffmpeg",
    "gemini",
    "ai-video",
    "shorts",
    "tiktok",
    "youtube-shorts",
    "viral-content"
  ],
  "author": "htekdev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/htekdev/vidpipe-copilot-plugin.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@google/generative-ai": "^0.24.0",
    "@types/node": "^22.15.2",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1",
    "zod": "^3.24.0"
  }
}
